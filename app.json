{
  "expo": {
    "name": "Nutrihabitocc",
    "slug": "nutrihabitoccmovilexpo",
    "version": "1.0.1",
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./notifee-plugin.js",
      "./firebase-podfile-plugin.js"
    ],
    "orientation": "portrait",
    "icon": "./assets/icono-ios.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.universalworldtechnologyec.nutrihabitoccmovil",
      "appDelegateLanguage": "objc",
      "googleServicesFile": "./GoogleService-Info.plist",
      "versionCode": 100
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icono.png",
        "backgroundColor": "#ffffff"
      },
      "notification": {
        "icon": "./assets/notificacion-icon.png", 
        "color": "#ffffff" 
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "package": "org.universalworldtechnologyec.nutrihabitoccmovil",
      "googleServicesFile": "./google-services.json",
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "imageWidth": 200
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
